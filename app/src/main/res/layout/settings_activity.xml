<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="5dp"
                android:src="@drawable/volume" />

            <ImageView
                android:layout_width="48dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="5dp"
                android:src="@drawable/brightness"/>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="5dp"
                android:src="@drawable/themes"/>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="5dp"
                android:src="@drawable/permissions"/>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="5dp"
                android:src="@drawable/help"/>
        </LinearLayout>

        <!-- Правая колонка с кнопками настроек -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVolume"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rounded_button"
                android:text="Громкость"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="8pt"
                android:fontFamily="arial"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBrightness"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rounded_button"
                android:text="Экран и яркость"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="8pt"
                android:fontFamily="arial"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnThemes"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rounded_button"
                android:text="Темы"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="8pt"
                android:fontFamily="arial"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPermissions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rounded_button"
                android:text="Разрешения"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="8pt"
                android:fontFamily="arial"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnHelp"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rounded_button"
                android:text="О приложении / Помощь"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="8pt"
                android:fontFamily="arial"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:background="@drawable/rounded_button"
        android:text="Выйти"
        android:textColor="@color/white"
        android:gravity="center"
        android:textSize="8pt"
        android:fontFamily="arial"/>

</LinearLayout>